# ─── Entorno: DEVELOP ─────────────────────────────────────────────────────────
# Copia este archivo a .env antes de levantar el servicio:
#   cp .env.dev.example .env
#
# Prerequisito: accesorios-dm-database debe estar clonado como directorio hermano
# (../accesorios-dm-database) para que Liquibase pueda aplicar las migraciones.
# Si está en otra ruta, ajusta DATABASE_REPO_PATH.

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
IMAGE_TAG=dev

# ── Rutas de repos hermanos ───────────────────────────────────────────────────
DATABASE_REPO_PATH=../accesorios-dm-database

# ── PostgreSQL (usuario administrador — solo para dev y Liquibase) ────────────
POSTGRES_DB=accesorios_dm_db
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=admin123
POSTGRES_PORT=5432

# ── Conexión del servicio a PostgreSQL ────────────────────────────────────────
# DB_HOST: nombre del servicio postgres dentro de la red Docker.
# Cambia a 'localhost' si postgres corre fuera de Docker.
DB_HOST=postgres
DB_PORT=5432

# DB_USERNAME: usuario de servicio con permisos restringidos a schemas
#              catalogo e inventario (ADR-005 R4).
#
# NOTA: el usuario correcto según ADR-005 es 'svc_inventory'.
# Para usarlo, el repo accesorios-dm-database debe haber ejecutado
# el changeset de creación de este usuario (pendiente implementar).
# Mientras tanto, usar 'admin' para desarrollo local.
DB_USERNAME=admin
DB_PASSWORD=admin123

# ── Puertos expuestos ─────────────────────────────────────────────────────────
INVENTORY_PORT=8082
