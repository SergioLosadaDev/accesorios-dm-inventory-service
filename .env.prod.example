# ─── Entorno: PRODUCCIÓN ──────────────────────────────────────────────────────
# Estructura de referencia. Los valores reales se gestionan mediante
# GitHub Secrets o un secret manager (Vault, AWS SSM, etc.).
#
# NUNCA completar ni commitear este archivo con valores reales.
# En producción, postgres y liquibase NO se levantan desde este compose
# (ver docker-compose.prod.yml — ambos servicios tienen profile "disabled").
# La base de datos en producción es una instancia externa gestionada.

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=prod
IMAGE_TAG=<inyectado por pipeline>

# ── Conexión del servicio ─────────────────────────────────────────────────────
POSTGRES_DB=accesorios_dm_db
DB_HOST=<host de la BD en producción>
DB_PORT=5432
DB_USERNAME=svc_inventory
DB_PASSWORD=<GitHub Secret: SVC_INVENTORY_PASSWORD>

# ── Puertos ───────────────────────────────────────────────────────────────────
# En producción el servicio no expone puerto al host (ver docker-compose.prod.yml)
INVENTORY_PORT=8082
