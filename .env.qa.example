# ─── Entorno: QA ──────────────────────────────────────────────────────────────
# Copia este archivo a .env.qa y completa los valores marcados con <completar>:
#   cp .env.qa.example .env.qa
#
# NUNCA commitear .env.qa con valores reales.
# En QA la base de datos es gestionada externamente — postgres del compose
# puede omitirse si ya existe una instancia QA levantada.

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=qa
IMAGE_TAG=qa

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=accesorios_dm_db
POSTGRES_ADMIN_USER=<completar>
POSTGRES_ADMIN_PASSWORD=<completar>
POSTGRES_PORT=5432

# ── Conexión del servicio ─────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=svc_inventory
DB_PASSWORD=<completar: password de svc_inventory en QA>

# ── Puertos expuestos ─────────────────────────────────────────────────────────
# En QA postgres no expone puerto al host (ver docker-compose.qa.yml)
INVENTORY_PORT=8082
